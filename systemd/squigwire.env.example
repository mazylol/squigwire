# Copy to ~/.config/squigwire/squigwire.env and edit as needed.
#
# Optional: force a specific real sink node for output.
# Find node names with: wpctl inspect @DEFAULT_AUDIO_SINK@ | grep node.name
# SQW_REAL_SINK_NODE=alsa_output.usb-Your_Device-00.HiFi__Line__sink
#
# Optional: custom virtual sink name
# PEQ_SINK_NAME=peq_in
#
# Optional: config path read by squigwire at startup
# SQW_CONFIG_PATH=~/.config/squigwire/squigwire.conf
